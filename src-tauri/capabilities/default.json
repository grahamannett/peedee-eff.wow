{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:event:default",
		"dialog:default",
		"dialog:allow-open",
		"fs:default",
		"fs:allow-read-text-file",
		"fs:read-all",
		"shell:default",
		"shell:allow-open",
		"store:default"
	]
}
